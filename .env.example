# civil3d-mcp  –  environment variables
# Copy to .env and adjust as needed.
# The server reads these at startup via os.getenv().

# Optional: explicit path to the Civil 3D binary folder
# (the folder that contains AeccDbMgd.dll, AeccLandMgd.dll, acdbmgd.dll)
# Default: auto-detected from standard Autodesk install paths (2023-2025).
# CIVIL3D_BIN_PATH=C:\Program Files\Autodesk\AutoCAD 2024

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
